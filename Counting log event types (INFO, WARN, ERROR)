#include <iostream>
#include <unordered_map>
#include <vector>
using namespace std;

int main() {
    vector<string> logs = {"INFO", "ERROR", "INFO", "WARN", "ERROR", "INFO"};

    unordered_map<string, int> freq;

    
    for (const string& log : logs) {
        freq[log]++;
    }

    for (auto &p : freq) {
        cout << p.first << " -> " << p.second << endl;
    }

    string mostCommon;
    int maxCount = 0;

    for (auto &p : freq) {
        if (p.second > maxCount) {
            maxCount = p.second;
            mostCommon = p.first;
        }
    }

    cout << "Most common event: " << mostCommon << endl;
}